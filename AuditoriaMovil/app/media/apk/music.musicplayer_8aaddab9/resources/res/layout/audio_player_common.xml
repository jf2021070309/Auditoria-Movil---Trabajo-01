<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <View android:background="#1affffff" android:layout_width="match_parent" android:layout_height="1px"/>
    <LinearLayout android:orientation="horizontal" android:background="#33ffffff" android:paddingTop="2dp" android:paddingBottom="2dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:textAppearance="?android:attr/textAppearanceMedium" android:textSize="14sp" android:layout_gravity="center" android:id="@+id/currenttime" android:paddingLeft="@dimen/portrait_album_art_padding" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:fontFamily="sans-serif-light"/>
        <SeekBar android:layout_gravity="center" android:id="@android:id/progress" android:paddingLeft="8dp" android:paddingRight="8dp" android:layout_width="0dp" android:layout_height="36dp" android:progressDrawable="@drawable/progress_horizontal" android:thumb="@drawable/progress_thumb" android:layout_weight="4" style="?android:attr/progressBarStyleHorizontal"/>
        <TextView android:textAppearance="?android:attr/textAppearanceMedium" android:textSize="14sp" android:gravity="right" android:layout_gravity="center" android:id="@+id/totaltime" android:paddingRight="@dimen/portrait_album_art_padding" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:fontFamily="sans-serif-light"/>
    </LinearLayout>
    <LinearLayout android:gravity="center" android:layout_gravity="center" android:orientation="horizontal" android:background="#1affffff" android:layout_width="match_parent" android:layout_height="75dp">
        <ImageView android:id="@+id/shuffle" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>
        <com.android.music.RepeatingImageButton android:id="@+id/prev" android:background="@color/transparent" android:layout_width="0dp" android:layout_height="match_parent" android:src="@drawable/btn_prev" android:layout_weight="1"/>
        <ImageView android:id="@+id/pause" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>
        <com.android.music.RepeatingImageButton android:id="@+id/next" android:background="@color/transparent" android:layout_width="0dp" android:layout_height="match_parent" android:src="@drawable/btn_next" android:layout_weight="1"/>
        <ImageView android:id="@+id/repeat" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>
    </LinearLayout>
</merge>
