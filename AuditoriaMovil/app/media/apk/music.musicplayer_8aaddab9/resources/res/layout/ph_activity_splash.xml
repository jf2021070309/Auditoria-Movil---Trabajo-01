<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" android:background="@color/ph_splash_background" android:layout_width="match_parent" android:layout_height="match_parent">
    <ImageView android:id="@+id/ph_splash_logo_image" android:layout_width="100dp" android:layout_height="100dp" android:layout_centerInParent="true"/>
    <TextView android:textSize="22dp" android:textColor="@color/ph_text_dark" android:layout_gravity="center_horizontal" android:id="@+id/ph_splash_title_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="42dp" android:layout_alignParentBottom="true" android:layout_centerHorizontal="true"/>
    <ProgressBar android:id="@+id/ph_splash_progress" android:visibility="gone" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginBottom="32dp" android:layout_above="@+id/ph_splash_title_text" android:layout_centerHorizontal="true"/>
</RelativeLayout>
