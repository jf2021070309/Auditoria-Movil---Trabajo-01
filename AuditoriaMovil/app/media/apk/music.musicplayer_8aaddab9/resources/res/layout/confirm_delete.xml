<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
    <TextView android:id="@+id/prompt" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:layout_marginTop="8dp" android:layout_marginRight="8dp" android:layout_marginBottom="8dp" android:drawableLeft="@android:drawable/ic_dialog_alert" android:drawablePadding="8dp"/>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/ad_dialog_height_margin" android:layout_marginBottom="10dp">
        <ImageView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <TextView android:textSize="18sp" android:textColor="#8d8d8d" android:gravity="center" android:id="@+id/cancel" android:background="@drawable/iv_ad_btn_dec" android:clickable="true" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="10dp" android:minHeight="40dp" android:text="@string/cancel" android:singleLine="true"/>
        <TextView android:textSize="18sp" android:textColor="@color/accent" android:gravity="center" android:id="@+id/delete" android:background="@drawable/iv_ad_btn" android:clickable="true" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="10dp" android:minHeight="40dp" android:text="@string/delete_item" android:singleLine="true"/>
    </LinearLayout>
</LinearLayout>
