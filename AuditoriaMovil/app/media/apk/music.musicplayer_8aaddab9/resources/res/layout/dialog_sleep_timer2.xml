<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:orientation="vertical" android:background="@drawable/iv_dialog_background" android:paddingLeft="24dp" android:paddingRight="24dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:textSize="@dimen/dialog_title_text_size" android:textColor="@color/dialog_text_title_color" android:ellipsize="marquee" android:layout_gravity="center_vertical" android:id="@+id/tv_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:singleLine="true" android:fontFamily="sans-serif-light"/>
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <SeekBar android:id="@+id/seekbar_hour" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="10dp" android:layout_marginTop="12dp" android:layout_marginRight="10dp" android:max="12" android:progress="0"/>
            <TextView android:textColor="@color/dialog_text_message_color" android:gravity="center" android:id="@+id/tv_hour" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true" android:fontFamily="sans-serif-light"/>
            <SeekBar android:id="@+id/seekbar_minute" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="10dp" android:layout_marginTop="12dp" android:layout_marginRight="10dp" android:max="60" android:progress="30"/>
            <TextView android:textColor="@color/dialog_text_message_color" android:gravity="center" android:id="@+id/tv_minute" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true" android:fontFamily="sans-serif-light"/>
            <CheckBox android:textColor="@color/dialog_text_message_color" android:id="@+id/play_rest_of_song" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="18dp">
            <TextView android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
            <TextView android:textSize="14sp" android:textColor="@color/dialog_text_message_color" android:gravity="center" android:id="@+id/cancel" android:background="@drawable/iv_btn_ripple" android:padding="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="88dp" android:minHeight="40dp" android:fontFamily="sans-serif-light"/>
            <TextView android:textSize="14sp" android:textColor="@color/dialog_positive_btn_color" android:gravity="center" android:id="@+id/create" android:background="@drawable/iv_btn_ripple" android:padding="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="88dp" android:minHeight="40dp" android:fontFamily="sans-serif-light"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
