<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:gravity="top" android:layout_width="match_parent" android:layout_height="match_parent">
    <FrameLayout android:orientation="vertical" android:background="#88000000" android:layout_width="match_parent" android:layout_height="match_parent">
        <ImageView android:id="@+id/touch" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
            <LinearLayout android:orientation="vertical" android:id="@+id/header" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:textSize="16sp" android:textColor="#e91e63" android:layout_gravity="right" android:id="@+id/attribution" android:paddingTop="5dp" android:paddingRight="16dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ad"/>
                <ImageView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="0.8"/>
                <TextView android:textSize="@dimen/purchase_ad_header_text_size" android:textColor="@android:color/white" android:gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/rp_awesome"/>
                <TextView android:textColor="@android:color/white" android:gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:text="@string/rp_so"/>
                <ImageView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
            </LinearLayout>
            <ImageView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="0.3"/>
            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="3"/>
                <ImageView android:layout_gravity="center" android:visibility="visible" android:layout_width="@dimen/purchase_ad_item_size" android:layout_height="@dimen/purchase_ad_item_size" app:srcCompat="@drawable/ic_rp_eq"/>
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1"/>
                <ImageView android:visibility="visible" android:layout_width="@dimen/purchase_ad_item_size" android:layout_height="@dimen/purchase_ad_item_size" app:srcCompat="@drawable/ic_rp_tag_editing"/>
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1"/>
                <ImageView android:layout_gravity="center" android:visibility="visible" android:layout_width="@dimen/purchase_ad_item_size" android:layout_height="@dimen/purchase_ad_item_size" app:srcCompat="@drawable/ic_rp_manage_art"/>
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1"/>
                <ImageView android:layout_gravity="center" android:visibility="visible" android:layout_width="@dimen/purchase_ad_item_size" android:layout_height="@dimen/purchase_ad_item_size" app:srcCompat="@drawable/ic_rp_video"/>
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1"/>
                <ImageView android:layout_gravity="center" android:visibility="visible" android:layout_width="@dimen/purchase_ad_item_size" android:layout_height="@dimen/purchase_ad_item_size" app:srcCompat="@drawable/ic_rp_ratings"/>
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1"/>
                <ImageView android:layout_gravity="center" android:visibility="visible" android:layout_width="@dimen/purchase_ad_item_size" android:layout_height="@dimen/purchase_ad_item_size" app:srcCompat="@drawable/ic_rp_themes"/>
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="3"/>
            </LinearLayout>
            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="3"/>
                <TextView android:gravity="center" android:layout_gravity="center" android:layout_width="@dimen/purchase_ad_item_size" android:layout_height="wrap_content" android:text="@string/rp_equalizer"/>
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1"/>
                <TextView android:gravity="center" android:layout_gravity="center" android:layout_width="@dimen/purchase_ad_item_size" android:layout_height="wrap_content" android:text="@string/rp_edit_tag"/>
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1"/>
                <TextView android:gravity="center" android:layout_gravity="center" android:layout_width="@dimen/purchase_ad_item_size" android:layout_height="wrap_content" android:text="@string/rp_manage_art"/>
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1"/>
                <TextView android:gravity="center" android:layout_gravity="center" android:layout_width="@dimen/purchase_ad_item_size" android:layout_height="wrap_content" android:text="@string/rp_videos"/>
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1"/>
                <TextView android:gravity="center" android:layout_gravity="center" android:layout_width="@dimen/purchase_ad_item_size" android:layout_height="wrap_content" android:text="@string/rp_ratings"/>
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1"/>
                <TextView android:gravity="center" android:layout_gravity="center" android:layout_width="@dimen/purchase_ad_item_size" android:layout_height="wrap_content" android:text="@string/themes"/>
                <ImageView android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="3"/>
            </LinearLayout>
            <ImageView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="0.3"/>
            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="@dimen/purchase_ad_item_size">
                <TextView android:textSize="16sp" android:textColor="@android:color/white" android:gravity="center" android:layout_gravity="center" android:id="@+id/cancel" android:background="#a6abad" android:paddingTop="4dp" android:paddingBottom="4dp" android:layout_width="0dp" android:layout_height="@dimen/purchase_ad_item_size" android:text="@android:string/cancel" android:layout_weight="1.5"/>
                <TextView android:textSize="28sp" android:textColor="@android:color/white" android:gravity="center" android:layout_gravity="center" android:id="@+id/unlock" android:background="@color/skin_color" android:paddingLeft="58dp" android:paddingTop="4dp" android:paddingRight="58dp" android:paddingBottom="4dp" android:layout_width="0dp" android:layout_height="@dimen/purchase_ad_item_size" android:text="@string/rp_try" android:layout_weight="3"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
