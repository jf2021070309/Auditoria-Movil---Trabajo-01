#include "../commons/defines.sh"
#include "../commons/uniforms.sh"
#include "../commons/varyings.sh"

#ifdef ENABLE_COLORIZE
	uniform lowp float LIGHTNESS;
	uniform lowp float SATURATION;
#endif
#ifdef ENABLE_GOLD
	uniform lowp float HIGHLIGHT;
#endif

void main()
{

#ifdef BLUR_1D
	// Blurred texture lookup
	// IMG: apply texcoord offsets in the vertex shader 
	lowp vec3 blur  = texture2D(BASEMAP, V_BlurTexCoord[0]).rgb * 0.0588235;
	blur		   += texture2D(BASEMAP, V_BlurTexCoord[1]).rgb * 0.2352941;
	blur		   += texture2D(BASEMAP, V_BlurTexCoord[2]).rgb * 0.4117647;
	blur		   += texture2D(BASEMAP, V_BlurTexCoord[3]).rgb * 0.2352941;
	blur		   += texture2D(BASEMAP, V_BlurTexCoord[4]).rgb * 0.0588235;	
	lowp vec4 color = vec4(blur, 1);
		
#else

	#ifdef DISABLE_TEXTURE
		#ifdef ENABLE_VERTEXCOLOR
			lowp vec4 color = V_VertexColor;
		#else
			lowp vec4 color = DIFFUSEC;
		#endif
	#else
		lowp vec4 color = texture2D( BASEMAP, V_TexCoord0 );
		#if defined(ENABLE_VERTEXCOLOR_MODULATE)
			color *= V_VertexColor;		
		#elif defined(ENABLE_DIFFUSE_MODULATE)
			// We're not using vertex colors, so we'll just use DIFFUSEC instead of those
			#ifdef ENABLE_COLORIZE
				lowp float grayscale = (color.r + color.g + color.b) * 0.333;
				
				#ifdef ENABLE_GOLD
					lowp float highlight = HIGHLIGHT * grayscale * grayscale;
					grayscale = 1.0 - grayscale;
					grayscale = 1.0 - grayscale * grayscale + LIGHTNESS * color.a;
					color = vec4(grayscale, grayscale, grayscale, color.a) * DIFFUSEC + highlight;
				#else
					lowp vec4 grayscaleVec = vec4(grayscale, grayscale, grayscale, color.a);
					lowp float lightness = LIGHTNESS * color.a;
					color = mix(grayscaleVec, color, SATURATION) * DIFFUSEC;
					color = vec4(color.r + lightness, color.g + lightness, color.b + lightness, color.a);
				#endif
			#else
				color *= DIFFUSEC;
			#endif
		#else
			#ifdef ENABLE_VERTEXCOLOR_COLORIZE
				// Use of MAD optimization
				lowp float gray = 0.33333 * color.r + 0.33333 * color.g + 0.33333 * color.b;

				color.rgb = V_VertexColor.rgb * gray;

				color.a *= V_VertexColor.a;
			#endif
			#ifdef ENABLE_VERTEXCOLOR_SILHOUETTE
				color.rgb = V_VertexColor.rgb;
				color.a *= V_VertexColor.a;
			#endif
		#endif
	#endif
#endif

#ifdef ENABLE_ALPHA_MASK
	color.a *= texture2D( BASEMAP1, V_TexCoord1 ).a;
#endif

#ifdef ENABLE_ALPHA_FACTOR
	color *= ALPHA_FACTOR;
#endif

	gl_FragColor = color;
}
