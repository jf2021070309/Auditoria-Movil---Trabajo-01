#include "../commons/defines.sh"
#include "../commons/uniforms.sh"
#include "../commons/varyings.sh"

const mediump float i2PI = 0.15915494309; // 1/(2PI)

uniform mediump float spokes;
uniform mediump float spokeWidth;
uniform mediump float spokeBorder;
uniform mediump float backgroundFadeDistance;

void main()
{
    mediump vec2 diff = /*V_TexCoord0 - */ vec2(0.5,0.5);
    
    //angular position
    mediump float angle = atan(diff.y, diff.x) * i2PI + 0.5; //atan returns [-PI,PI], transforms to [0,1]
    mediump float frac = fract(angle * spokes);
    mediump float toSpokeCenter = abs(frac-0.5)*2.0;
    
    //transition between on- and off-spoke
	mediump float spoke = smoothstep(0.0,spokeBorder,sqrt(2.0*length(diff)*(toSpokeCenter-spokeWidth)));
    
	mediump float len = length(diff)*2.0;
	mediump float dist = 1.0-len;
	mediump float bgAlpha = 1.0-len/backgroundFadeDistance;

	lowp vec4 color = mix(vec4(SPECULARC.rgb, SPECULARC.a * bgAlpha), vec4(DIFFUSEC.rgb, DIFFUSEC.a * dist), spoke);
	
	#ifdef ENABLE_ALPHA_FACTOR
		color *= ALPHA_FACTOR;
	#endif
    
	gl_FragColor = color;
}
