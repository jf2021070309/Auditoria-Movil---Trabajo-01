<?xml version="1.0" encoding="utf-8"?>
<com.kwad.sdk.core.view.AdBaseFrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:id="@+id/ksad_splash_root_container" android:layout_width="match_parent" android:layout_height="match_parent">
    <FrameLayout android:id="@+id/splash_play_card_view" android:background="@android:color/white" android:layout_width="match_parent" android:layout_height="match_parent">
        <ImageView android:id="@+id/ksad_splash_background" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop"/>
        <com.kwad.components.core.video.DetailVideoView android:layout_gravity="center" android:id="@+id/ksad_splash_video_player" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <ImageView android:layout_gravity="center" android:id="@+id/ksad_splash_foreground" android:visibility="invisible" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter"/>
        <ImageView android:id="@+id/ksad_splash_actionbar_full_screen" android:visibility="gone" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent" android:src="@android:color/transparent"/>
        <ViewStub android:id="@+id/ksad_splash_slideTouchView" android:layout="@layout/ksad_layout_splash_slideview" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <ViewStub android:layout_gravity="bottom" android:id="@+id/ksad_splash_actionbar_native_stub" android:visibility="gone" android:layout="@layout/ksad_splash_action_native" android:layout_width="match_parent" android:layout_height="@dimen/ksad_splash_actionbar_height" android:layout_marginBottom="@dimen/ksad_splash_actionbar_margin_bottom"/>
        <FrameLayout android:id="@+id/ksad_splash_webview_container" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <FrameLayout android:id="@+id/splash_tk_play_card_view" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <View android:layout_gravity="right" android:id="@+id/ksad_skip_view_area" android:visibility="gone" android:layout_width="154dp" android:layout_height="118dp"/>
        <ViewStub android:id="@+id/ksad_splash_left_top_view_stub" android:layout="@layout/ksad_splash_left_top" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <ViewStub android:id="@+id/ksad_splash_right_top_view_stub" android:layout="@layout/ksad_splash_right_top" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <com.kwad.components.core.widget.KsLogoView android:layout_gravity="bottom|left" android:id="@+id/ksad_splash_logo_container" android:background="@drawable/ksad_splash_logo_bg" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <ImageView android:layout_gravity="top|right" android:id="@+id/ksad_splash_sound" android:visibility="gone" android:layout_width="34dp" android:layout_height="30dp" android:layout_marginTop="16dp" android:layout_marginRight="16dp" android:src="@drawable/ksad_splash_sound_selector" android:scaleType="fitCenter"/>
        <include android:layout_gravity="bottom|center_horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" layout="@layout/ksad_splash_bottom_view"/>
    </FrameLayout>
    <FrameLayout android:id="@+id/splash_end_card_view" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent"/>
    <ViewStub android:id="@+id/ksad_splash_endcard_view_stub" android:layout="@layout/ksad_splash_end_card_native" android:layout_width="match_parent" android:layout_height="match_parent"/>
</com.kwad.sdk.core.view.AdBaseFrameLayout>
