<?xml version="1.0" encoding="utf-8"?>
<selector>
    <item n1:state_focused="true" n1:state_enabled="false">
        <shape n1:shape="rectangle">
            <corners n1:radius="@dimen/com_facebook_button_corner_radius"/>
            <solid n1:color="@color/com_facebook_button_background_color_focused_disabled"/>
        </shape>
    </item>
    <item n1:state_focused="false" n1:state_enabled="false">
        <shape n1:shape="rectangle">
            <corners n1:radius="@dimen/com_facebook_button_corner_radius"/>
            <solid n1:color="@color/com_facebook_button_background_color_disabled"/>
        </shape>
    </item>
    <item n1:state_focused="true">
        <shape n1:shape="rectangle">
            <corners n1:radius="@dimen/com_facebook_button_corner_radius"/>
            <solid n1:color="@color/com_facebook_button_background_color_focused"/>
            <stroke n1:width="1dp" n1:color="@color/com_facebook_button_border_color_focused"/>
        </shape>
    </item>
    <item n1:state_pressed="true">
        <shape n1:shape="rectangle">
            <corners n1:radius="@dimen/com_facebook_button_corner_radius"/>
            <solid n1:color="@color/com_facebook_button_background_color_pressed"/>
        </shape>
    </item>
    <item>
        <shape n1:shape="rectangle">
            <corners n1:radius="@dimen/com_facebook_button_corner_radius"/>
            <solid n1:color="@color/com_facebook_button_background_color"/>
        </shape>
    </item>
</selector>
