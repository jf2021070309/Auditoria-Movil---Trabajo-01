<?xml version="1.0" encoding="utf-8"?>
<layer-list>
    <item n1:drawable="@drawable/messenger_button_send_round_shadow"/>
    <item n1:left="1dp" n1:top="1dp" n1:right="1dp" n1:bottom="2dp">
        <selector>
            <item n1:state_pressed="true">
                <shape n1:shape="oval">
                    <solid n1:color="#ffebebeb"/>
                </shape>
            </item>
            <item>
                <shape n1:shape="oval">
                    <solid n1:color="#ffffffff"/>
                </shape>
            </item>
        </selector>
    </item>
    <item n1:left="1dp" n1:top="1dp" n1:right="1dp" n1:bottom="2dp">
        <bitmap n1:gravity="center" n1:src="@drawable/messenger_bubble_large_blue"/>
    </item>
</layer-list>
