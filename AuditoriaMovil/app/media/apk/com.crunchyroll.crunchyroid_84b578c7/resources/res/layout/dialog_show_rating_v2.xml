<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_gravity="center" android:id="@+id/content_container" android:background="@drawable/ratings_dialog_background" android:focusable="true" android:clickable="true" style="@style/ShowRatingDialog">
        <include android:id="@+id/toolbar" android:layout_width="0dp" android:layout_height="wrap_content" app:layout_constraintLeft_toLeftOf="0" app:layout_constraintRight_toRightOf="0" app:layout_constraintTop_toTopOf="0" layout="@layout/dialog_toolbar_layout"/>
        <ScrollView android:background="@color/ratings_dialog_background" android:layout_width="0dp" android:layout_height="@dimen/rating_dialog_scroll_view_height" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintHeight_max="@dimen/content_rating_content_max_height" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/toolbar">
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <ImageView android:id="@+id/user_rating_poster_image" android:background="@color/cr_woodsmoke" android:layout_width="@dimen/rating_dialog_poster_image_width" android:layout_height="@dimen/rating_dialog_poster_image_height" android:layout_marginTop="24dp" android:scaleType="centerCrop" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" style="@style/UserRatingPosterImage"/>
                <TextView android:textColor="@color/color_white" android:ellipsize="end" android:id="@+id/user_rating_show_title" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="@dimen/show_title_margin_top" android:maxLines="2" android:includeFontPadding="false" android:textAlignment="center" android:layout_marginHorizontal="@dimen/rating_dialog_horizontal_content_margin_horizontal" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/user_rating_poster_image" style="@style/Subheader1LatoSemibold"/>
                <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/user_rating_container" android:paddingTop="16dp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/rating_dialog_horizontal_content_margin_horizontal" android:layout_marginEnd="@dimen/rating_dialog_horizontal_content_margin_horizontal" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/user_rating_show_title">
                    <TextView android:textColor="@color/cr_silver_chalice" android:id="@+id/user_rating_header" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/show_rating_dialog_v2_need_rating" android:includeFontPadding="false" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" style="@style/BodyLatoSemibold"/>
                    <com.ellation.crunchyroll.ui.userratingbar.UserRatingBar android:id="@+id/user_rating_rating_bar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/user_rating_header"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <com.ellation.crunchyroll.showrating.ratingdialogv2.widgets.AverageRatingLayout android:id="@+id/average_rating_layout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="40dp" android:layout_marginStart="@dimen/rating_dialog_horizontal_content_margin_horizontal" android:layout_marginEnd="@dimen/rating_dialog_horizontal_content_margin_horizontal" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/user_rating_container"/>
                <com.ellation.crunchyroll.showrating.ratingdialogv2.widgets.RatingProgressLayout android:id="@+id/average_rating_progress_layout" android:paddingBottom="24dp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:layout_marginStart="@dimen/rating_dialog_horizontal_content_margin_horizontal" android:layout_marginEnd="@dimen/rating_dialog_horizontal_content_margin_end" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/average_rating_layout"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>
        <FrameLayout android:id="@+id/show_rating_progress" android:background="@color/ratings_dialog_loading_state_background" android:focusable="true" android:visibility="gone" android:clickable="true" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintLeft_toLeftOf="0" app:layout_constraintRight_toRightOf="0" app:layout_constraintTop_toBottomOf="@+id/toolbar">
            <include layout="@layout/progress_layout"/>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <FrameLayout android:layout_gravity="bottom" android:id="@+id/errors_layout" android:layout_width="match_parent" android:layout_height="wrap_content"/>
</FrameLayout>
