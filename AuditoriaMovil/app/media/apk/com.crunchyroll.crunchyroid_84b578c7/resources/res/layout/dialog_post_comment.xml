<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:background="@color/transparent" android:layout_width="match_parent" android:layout_height="wrap_content">
    <FrameLayout android:id="@+id/cast_mini_controller_container" android:background="@color/black" android:layout_width="match_parent" android:layout_height="wrap_content">
        <include layout="@layout/fragment_cast_mini_controller"/>
    </FrameLayout>
    <FrameLayout android:id="@+id/message_layout_container" android:background="@color/black" android:layout_width="match_parent" android:layout_height="wrap_content">
        <com.crunchyroll.connectivity.ConnectionErrorBottomMessageLayout android:layout_gravity="bottom" android:id="@+id/comment_input_connection_error_layout" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </FrameLayout>
    <com.ellation.crunchyroll.commenting.comments.inputview.CommentsInputLayout android:id="@+id/comment_input_view" android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/CommentInputDialogUnderlineStyle"/>
</LinearLayout>
