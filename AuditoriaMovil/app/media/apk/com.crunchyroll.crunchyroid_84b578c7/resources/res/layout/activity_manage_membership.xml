<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar" android:background="@color/transparent" android:layout_width="0dp" android:layout_height="wrap_content" app:layout_constraintLeft_toLeftOf="0" app:layout_constraintRight_toRightOf="0" app:layout_constraintTop_toTopOf="0" style="@style/ToolbarWithNavigationIconStyle"/>
    <View android:id="@+id/toolbar_divider" android:background="@color/cr_black_pearl" android:layout_width="0dp" android:layout_height="1dp" android:layout_marginTop="@dimen/toolbar_divider_margin_top" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/toolbar"/>
    <ScrollView android:id="@+id/upsell_tiers_carousel_container" android:paddingBottom="30dp" android:clipToPadding="false" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintBottom_toTopOf="@+id/manage_membership_cta" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/toolbar_divider">
        <LinearLayout android:gravity="center_horizontal" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.ellation.widgets.tabs.TabDotsIndicatorView android:orientation="horizontal" android:id="@+id/upsell_tiers_tab_indicator" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/manage_membership_tab_indicator_margin_top"/>
            <com.ellation.crunchyroll.presentation.multitiersubscription.carouselv2.UpsellCarouselLayout android:id="@+id/upsell_tiers_carousel" android:paddingTop="@dimen/carousel_vertical_padding" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:textColor="@color/cr_silver_chalice" android:gravity="center" android:id="@+id/manage_membership_google_play" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/manage_membership_more_subscription_button_margin_top" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" style="@style/SmallLatoSemibold"/>
        </LinearLayout>
    </ScrollView>
    <ImageView android:layout_width="0dp" android:layout_height="24dp" android:src="@drawable/cr_plus_checkout_gradient_bottom" app:layout_constraintBottom_toTopOf="@+id/manage_membership_cta" app:layout_constraintLeft_toLeftOf="0" app:layout_constraintRight_toRightOf="0"/>
    <com.ellation.crunchyroll.presentation.multitiersubscription.manage.cta.ManageMembershipCtaButton android:id="@+id/manage_membership_cta" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" style="@style/ManageMembershipCta"/>
    <FrameLayout android:id="@+id/manage_membership_error" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintLeft_toLeftOf="0" app:layout_constraintRight_toRightOf="0" app:layout_constraintTop_toTopOf="0"/>
    <com.ellation.crunchyroll.presentation.multitiersubscription.alternativeflow.SubscriptionAlternativeFlowLayout android:id="@+id/manage_membership_alternative_flow" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintLeft_toLeftOf="0" app:layout_constraintRight_toRightOf="0" app:layout_constraintTop_toTopOf="0"/>
    <FrameLayout android:id="@+id/manage_membership_progress" android:background="@color/black" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp" android:elevation="6dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintLeft_toLeftOf="0" app:layout_constraintRight_toRightOf="0" app:layout_constraintTop_toTopOf="0">
        <include layout="@layout/progress_layout"/>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
