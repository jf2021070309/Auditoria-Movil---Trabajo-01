<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="horizontal" android:background="@color/transparent" android:paddingTop="16dp" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="wrap_content">
    <ImageView android:id="@+id/toolbar_back_button" android:background="?attr/selectableItemBackgroundBorderless" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_back" android:contentDescription="@string/desc_close" android:layout_marginStart="16dp"/>
    <LinearLayout android:orientation="vertical" android:id="@+id/title_subtitle_container" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="24dp" android:layout_marginEnd="40dp">
        <TextView android:textColor="@color/white" android:ellipsize="end" android:id="@+id/title" android:layout_width="match_parent" android:layout_height="wrap_content" android:lines="1" android:includeFontPadding="false" style="@style/Subheader1LatoMedium"/>
        <TextView android:textColor="@color/cr_white_opacity_60" android:ellipsize="end" android:id="@+id/subtitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:lines="1" android:includeFontPadding="false" style="@style/BodyLatoSemibold"/>
    </LinearLayout>
    <ImageView android:id="@+id/button_skip_to_next" android:background="?attr/selectableItemBackgroundBorderless" android:layout_width="24dp" android:layout_height="wrap_content" android:src="@drawable/ic_next_episode" android:contentDescription="@string/desc_player_toolbar_skip_episode" android:layout_marginEnd="24dp"/>
    <androidx.mediarouter.app.MediaRouteButton android:layout_gravity="top" android:id="@+id/media_route_button" android:visibility="gone" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="24dp" app:mediaRouteButtonTint="@color/color_white"/>
    <ImageView android:id="@+id/button_settings" android:background="?attr/selectableItemBackgroundBorderless" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_player_settings" android:contentDescription="@string/desc_player_toolbar_settings" android:layout_marginEnd="24dp"/>
    <ImageView android:id="@+id/button_toggle_fullscreen" android:background="?attr/selectableItemBackgroundBorderless" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_expand" android:contentDescription="@string/desc_player_toolbar_toggle_expansion" android:layout_marginEnd="24dp"/>
</LinearLayout>
