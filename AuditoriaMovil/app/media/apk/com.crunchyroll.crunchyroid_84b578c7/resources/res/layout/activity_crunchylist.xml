<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.coordinatorlayout.widget.CoordinatorLayout android:background="@color/black" android:layout_width="match_parent" android:layout_height="match_parent">
        <FrameLayout android:id="@+id/crunchylist_error_container" android:layout_width="match_parent" android:layout_height="match_parent" app:behavior_overlapTop="?attr/actionBarSize" app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
        <com.ellation.widgets.NestedScrollCoordinatorLayout android:id="@+id/nested_coordinator" android:layout_width="match_parent" android:layout_height="match_parent" app:layout_behavior="@string/appbar_scrolling_view_behavior">
            <com.google.android.material.appbar.AppBarLayout android:id="@+id/crunchylist_manage_appbar" android:layout_width="match_parent" android:layout_height="wrap_content">
                <include android:id="@+id/crunchylist_manage_toolbar" android:layout_width="match_parent" android:layout_height="48dp" app:layout_scrollFlags="snap|enterAlways|scroll" layout="@layout/layout_crunchylist_manage_toolbar"/>
            </com.google.android.material.appbar.AppBarLayout>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/crunchylist_recycler_view" android:paddingTop="8dp" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="match_parent" android:paddingEnd="@dimen/crunchylist_list_padding_horizontal" app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
        </com.ellation.widgets.NestedScrollCoordinatorLayout>
        <include android:id="@+id/crunchylist_empty_view" android:layout_width="match_parent" android:layout_height="match_parent" app:behavior_overlapTop="?attr/actionBarSize" app:layout_behavior="@string/appbar_scrolling_view_behavior" layout="@layout/layout_crunchylist_empty_state"/>
        <com.google.android.material.appbar.AppBarLayout android:id="@+id/collapsible_app_bar" android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.ellation.widgets.collapsibletoolbar.CollapsibleToolbarLayout android:id="@+id/collapsible_tool_bar" android:layout_width="match_parent" android:layout_height="wrap_content" app:collapsedTitleTextAppearance="@style/CollapsedAppBarTextStyle" app:contentScrim="@drawable/toolbar_background_divider" app:expandedTitleMarginBottom="8dp" app:expandedTitleMarginEnd="16dp" app:expandedTitleMarginStart="@dimen/crunchylist_expanded_title_margin_start" app:expandedTitleMarginTop="0dp" app:expandedTitleTextAppearance="@style/ExpandedAppBarTextStyle" app:layout_scrollFlags="snap|exitUntilCollapsed|scroll" app:maxLines="1000" app:toolbarId="@+id/toolbar">
                <View android:background="@color/black" android:layout_width="match_parent" android:layout_height="match_parent"/>
                <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar" android:background="@color/black" android:layout_width="match_parent" android:layout_height="?android:attr/actionBarSize" app:layout_collapseMode="pin" app:navigationIcon="@drawable/ic_back" style="@style/ToolbarWithNavigationIconStyle"/>
            </com.ellation.widgets.collapsibletoolbar.CollapsibleToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
    <FrameLayout android:id="@+id/crunchylist_fragment_container" android:layout_width="match_parent" android:layout_height="match_parent"/>
    <LinearLayout android:layout_gravity="bottom" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <FrameLayout android:id="@+id/crunchylist_snackbar_container" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <com.crunchyroll.connectivity.ConnectionErrorBottomMessageLayout android:id="@+id/crunchylist_connectivity_error" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>
</FrameLayout>
