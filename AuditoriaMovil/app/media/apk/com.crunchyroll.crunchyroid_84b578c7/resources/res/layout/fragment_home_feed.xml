<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout android:id="@+id/app_bar_layout" android:layout_width="match_parent" android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar" android:fitsSystemWindows="false" android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/ToolbarWithLogoStyle"/>
    </com.google.android.material.appbar.AppBarLayout>
    <com.ellation.crunchyroll.feed.HomeFeedScreenView android:id="@+id/home_feed" android:layout_width="match_parent" android:layout_height="match_parent" app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
    <com.ellation.crunchyroll.feed.subscriptionbutton.FeedSubscriptionButton android:id="@+id/subscription_button" android:paddingLeft="16dp" android:paddingRight="16dp" android:paddingBottom="16dp" android:layout_width="@dimen/home_feed_subscription_button_width" android:layout_height="wrap_content" app:layout_anchor="@+id/home_feed" app:layout_anchorGravity="bottom|center_horizontal" app:layout_behavior="com.ellation.widgets.behavior.HideBottomViewOnScrollBehavior" app:layout_dodgeInsetEdges="bottom"/>
    <FrameLayout android:id="@+id/snackbar_container" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_anchor="@+id/home_feed" app:layout_anchorGravity="bottom|center_horizontal" app:layout_dodgeInsetEdges="bottom"/>
    <com.crunchyroll.billingnotifications.ingrace.cta.InGraceFeedButton android:id="@+id/in_grace_feed_button" android:paddingLeft="16dp" android:paddingRight="16dp" android:paddingBottom="16dp" android:visibility="gone" android:layout_width="@dimen/home_feed_subscription_button_width" android:layout_height="wrap_content" app:layout_anchor="@+id/home_feed" app:layout_anchorGravity="bottom|center_horizontal" app:layout_behavior="com.ellation.widgets.behavior.HideBottomViewOnScrollBehavior" app:layout_dodgeInsetEdges="bottom"/>
    <com.ellation.crunchyroll.inappupdates.view.InAppUpdatesLayout android:id="@+id/in_app_updates_view" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_anchor="@+id/home_feed" app:layout_anchorGravity="bottom|center_horizontal" app:layout_insetEdge="bottom"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
